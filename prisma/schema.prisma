// MarineFlow — multi-tenant via Salon + Postgres RLS (salonId = spec tenant_id)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Maps to Nexus spec `tenant_status`
enum TenantStatus {
  LEAD
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CHURNED
}

enum AppointmentStatus {
  HELD
  CONFIRMED
  CONFIRMED_PAID
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum StaffRole {
  OWNER
  MANAGER
  STYLIST
  RECEPTIONIST
  VIEWER
}

enum MessageChannel {
  WHATSAPP
  SMS
  WEB
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

enum TicketStatus {
  OPEN
  WAITING_CUSTOMER
  RESOLVED
}

enum ConversationStep {
  GREETING
  MENU
  PICK_SERVICE
  PICK_STAFF
  PICK_DATE
  PICK_SLOT
  CONFIRM_BOOKING
  MANAGE_BOOKING
  COMPLAINT
  FAQ
  LOYALTY
  IDLE
}

model Salon {
  id             String       @id @default(cuid())
  /// Display / trading name (spec: trading_name)
  name           String
  tradingName    String?
  legalName      String?
  slug           String       @unique
  industryTemplate String     @default("salon")
  status         TenantStatus @default(TRIAL)
  statusChangedAt DateTime    @default(now())
  trialEndsAt    DateTime?
  tier           String       @default("starter")
  timezone       String       @default("America/New_York")
  defaultCurrency String      @default("usd")
  locale         String       @default("en")
  addressLine    String?
  parkingNotes   String?
  accessibility  String?
  phoneDisplay   String?
  botName        String       @default("Ava")
  botVoiceBrief  String?      @db.Text
  toneFormality  Int          @default(50)
  toneWarmth     Int          @default(70)
  tonePlayfulness Int         @default(40)
  tonePace       Int          @default(30)
  toneSalesEnergy Int         @default(30)
  /// Meta WhatsApp Cloud API phone_number_id
  whatsappPhoneId String?     @unique
  whatsappWabaId  String?
  /// Twilio sandbox/production From (e.g. whatsapp:+14155238886) for routing fallback
  twilioWhatsAppFrom String?  @unique
  onboardingCompletedAt DateTime?
  metadata       Json         @default("{}")
  deletedAt      DateTime?
  /** IANA — hours interpreted in this zone */
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  customers      Customer[]
  webhookEvents  WebhookEvent[]
  services       Service[]
  staff          Staff[]
  appointments   Appointment[]
  businessHours  BusinessHour[]
  workingHours   WorkingHour[]
  availabilityExceptions AvailabilityException[]
  conversations  Conversation[]
  payments       Payment[]
  invoices       Invoice[]
  loyaltyProgram LoyaltyProgram?
  tickets        Ticket[]
  faqItems       FaqItem[]
  staffUsers     StaffUser[]
  analyticsEvents AnalyticsEvent[]
}

model Customer {
  id              String    @id @default(cuid())
  salonId         String
  salon           Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade)
  waId            String    /** E.164 without whatsapp: prefix storage normalized */
  displayName     String?
  locale          String    @default("en")
  loyaltyStampsCached Int?  /** optional cache; source of truth is LoyaltyLedger */
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  conversations   Conversation[]
  messages        Message[]
  appointments    Appointment[]
  loyaltyLedgers  LoyaltyLedger[]
  tickets         Ticket[]
  payments        Payment[]

  @@unique([salonId, waId])
  @@index([salonId])
}

model Conversation {
  id          String            @id @default(cuid())
  salonId     String
  salon       Salon             @relation(fields: [salonId], references: [id], onDelete: Cascade)
  customerId  String
  customer    Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  step        ConversationStep  @default(GREETING)
  /** JSON blob: selectedServiceId, slotIso, staffId, pendingAppointmentId, undo stack */
  context     Json              @default("{}")
  updatedAt   DateTime          @updatedAt
  createdAt   DateTime          @default(now())

  messages    Message[]

  @@unique([salonId, customerId])
  @@index([customerId])
}

model Message {
  id             String         @id @default(cuid())
  conversationId String
  conversation   Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  customerId     String
  customer       Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  direction      String         /** in | out */
  body           String         @db.Text
  channel        MessageChannel @default(WHATSAPP)
  status         MessageStatus  @default(SENT)
  providerSid    String?        @unique
  idempotencyKey String?        @unique
  createdAt      DateTime       @default(now())

  @@index([conversationId])
}

model Service {
  id          String   @id @default(cuid())
  salonId     String
  salon       Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  name        String
  description String?
  durationMin Int
  bufferMin   Int      @default(0)
  priceCents  Int
  category    String?
  depositCents Int?    /** null = no deposit required */
  fullPay     Boolean  @default(false)
  qualifiesLoyalty Boolean @default(true)
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)

  staffLinks  StaffService[]
  appointments Appointment[]

  @@index([salonId])
}

model Staff {
  id            String   @id @default(cuid())
  salonId       String
  salon         Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  name          String
  displayName   String?
  bio           String?  @db.Text
  specialties   String[] @default([])
  avatarUrl     String?
  active        Boolean  @default(true)
  isBookable    Boolean  @default(true)
  breakMin      Int      @default(0)
  sortOrder     Int      @default(0)
  deletedAt     DateTime?

  services      StaffService[]
  appointments  Appointment[]
  timeOff       TimeOff[]
  workingHours  WorkingHour[]
  availabilityExceptions AvailabilityException[]
  staffUsers    StaffUser[]
  analyticsEvents AnalyticsEvent[]

  @@index([salonId])
}

model StaffService {
  staffId   String
  serviceId String
  staff     Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([staffId, serviceId])
}

model BusinessHour {
  id        String @id @default(cuid())
  salonId   String
  salon     Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)
  dayOfWeek Int    /** 0 = Sunday .. 6 = Saturday */
  openMin   Int    /** minutes from midnight */
  closeMin  Int

  @@unique([salonId, dayOfWeek])
}

model TimeOff {
  id      String   @id @default(cuid())
  staffId String
  staff   Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  start   DateTime
  end     DateTime
  reason  String?
}

/// Per-staff recurring weekly availability (spec: working_hours)
model WorkingHour {
  id            String   @id @default(cuid())
  salonId       String
  salon         Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  staffId       String
  staff         Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  weekday       Int      /// 0=Sun .. 6=Sat
  startTime     String   /// HH:MM (e.g. "09:00")
  endTime       String   /// HH:MM (e.g. "18:00")
  isBreak       Boolean  @default(false)
  effectiveFrom DateTime @default(now())
  effectiveUntil DateTime?

  @@index([staffId, weekday])
  @@index([salonId])
}

/// Overrides to recurring schedule (spec: availability_exceptions)
model AvailabilityException {
  id          String   @id @default(cuid())
  salonId     String
  salon       Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  staffId     String?
  staff       Staff?   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  startsAt    DateTime
  endsAt      DateTime
  reason      String?
  isAvailable Boolean  /// true = special-open, false = closed

  @@index([salonId])
  @@index([staffId])
}

model Appointment {
  id          String             @id @default(cuid())
  salonId     String
  salon       Salon              @relation(fields: [salonId], references: [id], onDelete: Cascade)
  customerId  String
  customer    Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  serviceId   String
  service     Service            @relation(fields: [serviceId], references: [id])
  staffId     String
  staff       Staff              @relation(fields: [staffId], references: [id])
  start       DateTime
  end         DateTime
  status      AppointmentStatus  @default(HELD)
  notes       String?
  depositInvoiceId String?
  loyaltyRedeemed Boolean        @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  payments    Payment[]
  invoices    Invoice[]
  analyticsEvents AnalyticsEvent[]

  @@index([salonId, start])
  @@index([staffId, start])
}

model Invoice {
  id             String   @id @default(cuid())
  salonId        String
  salon          Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  appointmentId  String?
  appointment    Appointment? @relation(fields: [appointmentId], references: [id])
  customerId     String
  currency       String   @default("usd")
  subtotalCents  Int
  taxCents       Int      @default(0)
  totalCents     Int
  createdAt      DateTime @default(now())

  payments       Payment[]
}

model Payment {
  id             String        @id @default(cuid())
  salonId        String
  salon          Salon         @relation(fields: [salonId], references: [id], onDelete: Cascade)
  appointmentId  String?
  appointment    Appointment?  @relation(fields: [appointmentId], references: [id])
  customerId     String
  customer       Customer      @relation(fields: [customerId], references: [id])
  invoiceId      String?
  invoice        Invoice?      @relation(fields: [invoiceId], references: [id])
  status         PaymentStatus @default(PENDING)
  amountCents    Int
  currency       String        @default("usd")
  stripeSessionId   String?
  stripePaymentIntentId String?
  stripeRefundId String?
  metadata       Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([salonId, createdAt])
  @@index([stripePaymentIntentId])
}

model LoyaltyProgram {
  id              String @id @default(cuid())
  salonId         String @unique
  salon           Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)
  stampsPerReward Int    @default(10)
  rewardKind      String @default("FREE_SERVICE_TIER") /** free qualifying service */
  createdAt       DateTime @default(now())

  ledger LoyaltyLedger[]
}

model LoyaltyLedger {
  id          String   @id @default(cuid())
  programId   String
  program     LoyaltyProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  delta       Int      /** +earn -redeem */
  reason      String
  appointmentId String?
  createdAt   DateTime @default(now())
  createdByStaffUserId String?

  @@index([customerId, createdAt])
}

model Ticket {
  id          String       @id @default(cuid())
  salonId     String
  salon       Salon        @relation(fields: [salonId], references: [id], onDelete: Cascade)
  customerId  String
  customer    Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  status      TicketStatus @default(OPEN)
  subject     String?
  assigneeStaffUserId String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  messages    TicketMessage[]
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  direction String   /** in | out | internal */
  body      String   @db.Text
  createdAt DateTime @default(now())
}

model FaqItem {
  id        String @id @default(cuid())
  salonId   String
  salon     Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)
  question  String
  answer    String @db.Text
  keywords  String[] @default([])
  sortOrder Int    @default(0)
}

model StaffUser {
  id           String    @id @default(cuid())
  salonId      String
  salon        Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade)
  email        String    @unique
  passwordHash String
  name         String
  role         StaffRole @default(STYLIST)
  staffId      String?
  staff        Staff?    @relation(fields: [staffId], references: [id])
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())

  auditLogs    AuditLog[]
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actor       StaffUser? @relation(fields: [actorUserId], references: [id])
  action      String
  entity      String
  entityId    String?
  payload     Json?
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model AnalyticsEvent {
  id            String   @id @default(cuid())
  salonId       String
  salon         Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  customerId    String?
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  staffId       String?
  staff         Staff?   @relation(fields: [staffId], references: [id])
  type          String   /** booking_started, booking_complete, csat, ... */
  payload       Json?
  createdAt     DateTime @default(now())

  @@index([salonId, type, createdAt])
}

/// Inbound webhook dedup + audit (spec: webhook_events)
model WebhookEvent {
  id           String   @id @default(cuid())
  salonId      String?
  salon        Salon?   @relation(fields: [salonId], references: [id], onDelete: SetNull)
  provider     String
  providerEventId String
  payload      Json
  verified     Boolean  @default(false)
  processedAt  DateTime?
  createdAt    DateTime @default(now())

  @@unique([provider, providerEventId])
  @@index([salonId, createdAt])
}
