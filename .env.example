# Copy to .env — never commit secrets
NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

DATABASE_URL=postgresql://salon:salon@localhost:5432/salon_whatsapp?schema=public

REDIS_URL=redis://localhost:6379

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Used for webhook signature validation — must match the URL Twilio calls (no trailing slash mismatch)
TWILIO_WEBHOOK_BASE_URL=http://localhost:3000

INTERNAL_API_KEY=dev-internal-key-change-me

# Stripe (payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Dashboard session
SESSION_SECRET=change-me-in-production-min-32-chars-long

# Slug of the default salon (must match what prisma/seed.ts creates)
DEFAULT_SALON_SLUG=demo-salon
