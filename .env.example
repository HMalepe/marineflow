# Copy to .env — never commit secrets
NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

DATABASE_URL=postgresql://salon:salon@localhost:5432/salon_whatsapp?schema=public

REDIS_URL=redis://localhost:6379

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Used for webhook signature validation — must match the URL Twilio calls (no trailing slash mismatch)
TWILIO_WEBHOOK_BASE_URL=http://localhost:3000

INTERNAL_API_KEY=dev-internal-key-change-me

# Stripe (payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Dashboard session
SESSION_SECRET=change-me-in-production-min-32-chars-long

# Tenant routing fallback (resolved by bot if no phone-id/to match)
DEFAULT_SALON_SLUG=demo-salon

# Messaging provider: twilio | meta
MESSAGING_PROVIDER=twilio

# Meta WhatsApp Cloud API
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
META_ACCESS_TOKEN=
META_API_VERSION=v21.0

# Ozow (SA EFT payments)
OZOW_SITE_CODE=
OZOW_PRIVATE_KEY=
OZOW_API_KEY=
OZOW_IS_TEST=true

# PayFast (SA card/EFT payments)
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_IS_TEST=true

# Inngest (background job queue)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- AI / Embeddings ---
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
