# ─── Core ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
DATABASE_URL=postgresql://marineflow:marineflow_dev@localhost:5432/marineflow
REDIS_URL=redis://localhost:6379
SESSION_SECRET=change-me-to-a-random-32-char-string
INTERNAL_API_KEY=change-me-to-a-random-16-char-key
DEFAULT_SALON_SLUG=demo-salon

# ─── Messaging ─────────────────────────────────────────────────────────
MESSAGING_PROVIDER=meta
# Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_WEBHOOK_BASE_URL=http://localhost:3000
# Meta WhatsApp Cloud API
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
META_ACCESS_TOKEN=
META_API_VERSION=v21.0

# ─── Payments ──────────────────────────────────────────────────────────
# PayFast (primary for subscriptions)
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
# Sandbox-only credentials (used when PAYFAST_IS_TEST=true)
PAYFAST_SANDBOX_MERCHANT_ID=
PAYFAST_SANDBOX_MERCHANT_KEY=
PAYFAST_SANDBOX_PASSPHRASE=
# false = live (www.payfast.co.za) | true = sandbox (sandbox.payfast.co.za)
PAYFAST_IS_TEST=false
# Ozow (instant EFT)
OZOW_SITE_CODE=
OZOW_PRIVATE_KEY=
OZOW_API_KEY=
OZOW_IS_TEST=true
# Stripe (optional international)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Background Jobs (Inngest) ─────────────────────────────────────────
# Production (Railway): copy both keys from app.inngest.com → Env → Keys
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# Local dev only — omit signing key and use INNGEST_DEV=1 with `npx inngest-cli dev`
INNGEST_DEV=1

# ─── AI ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ─── CORS & Security ──────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001

# ─── Sentry (optional) ────────────────────────────────────────────────
SENTRY_DSN=

# ─── S3-compatible Storage ────────────────────────────────────────────
S3_ENDPOINT=
S3_BUCKET=marineflow-uploads
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# ─── SMS & Voice (Twilio) ─────────────────────────────────────────────
TWILIO_SMS_FROM=
TWILIO_VOICE_FROM=
APP_BASE_URL=http://localhost:3000
