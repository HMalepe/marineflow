# MarineFlow dashboard (Next.js) — copy to .env.local for local dev

# API origin (required in production)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Optional: proxy API through the dashboard domain (corporate WiFi / same-origin)
# API_UPSTREAM_URL=https://marineflow.co.za

# ─── Troubleshooting ───────────────────────────────────────────────────
# Show full server + client error details on screen (stack, env, digest).
# Production: set on Vercel → Settings → Environment Variables, then redeploy.
# Turn OFF after fixing — visible to anyone who can open the dashboard.
NEXT_PUBLIC_DASHBOARD_DEBUG=false
